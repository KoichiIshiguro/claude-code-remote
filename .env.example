# Claude Code Remote — all of these are OPTIONAL.
# On first run you set the admin user, password, and working folder via the
# browser (http://localhost:4000/setup). That info is persisted to data/.
#
# Use this .env file only if you want to override the persisted defaults.

# HTTP port. Default: 4000.
# PORT=4000

# Root directory the project picker scans. Overrides the value chosen at /setup.
# BASE_DIR=/home/you/projects

# Absolute path to the `claude` binary.
# Set this when running under PM2 / systemd / launchd where PATH may not
# include ~/.local/bin.
# CLAUDE_PATH=/home/you/.local/bin/claude

# Long random string for signing session cookies. Auto-generated and saved to
# data/config.json on first start — you only need this if you want to share
# the same cookie domain across multiple deployments.
# SESSION_SECRET=

# Input-token count that triggers an auto-/compact before the next prompt.
# Default 167000 (Claude Code TUI's ~83.5% trigger on a 200k-context model).
# Set higher (e.g. 835000) if you're on a 1M-context tier.
# CLAUDE_AUTO_COMPACT_THRESHOLD=167000

# Set to "production" to enforce HTTPS-only session cookies.
# Only do this when you're terminating TLS in front of this server.
# NODE_ENV=production
