# Claude Code Remote — all of these are OPTIONAL.
# On first run you set the admin user, password, and access scope via the
# browser (http://localhost:4000/setup). That info is persisted to data/
# (admin.json, config.json), and registered projects live in projects.json.
#
# Use this .env file only if you want to override the persisted defaults.
# (The access scope and project list are managed in the UI, not via env vars.)

# HTTP port. Default: 4000.
# PORT=4000

# Absolute path to the `claude` binary.
# Set this when running under PM2 / systemd / launchd where PATH may not
# include ~/.local/bin.
# CLAUDE_PATH=/home/you/.local/bin/claude

# Long-lived auth token for headless / background runs (REQUIRED under launchd).
# A background service (launchd/systemd) cannot read the interactive login
# Keychain where `claude` normally keeps its OAuth credentials, so it falls back
# to a stale token and every API call fails with "401 Invalid authentication
# credentials". Fix: on the everyday GUI machine, run `claude setup-token` in a
# real terminal (it opens a browser to authorize — needs a TTY), then paste the
# printed sk-ant-oat01-... value here and restart the server.
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Long random string for signing session cookies. Auto-generated and saved to
# data/config.json on first start — you only need this if you want to share
# the same cookie domain across multiple deployments.
# SESSION_SECRET=

# Input-token count that triggers an auto-/compact before the next prompt.
# Default 167000 (Claude Code TUI's ~83.5% trigger on a 200k-context model).
# Set higher (e.g. 835000) if you're on a 1M-context tier.
# CLAUDE_AUTO_COMPACT_THRESHOLD=167000

# Absolute path to `tmux` for the built-in terminal. Auto-detected via
# `which tmux` when unset; if tmux is absent the terminal falls back to a
# plain (non-persistent) shell.
# TMUX_PATH=/opt/homebrew/bin/tmux

# Shell the built-in terminal launches. Default: `$SHELL -l`
# (powershell.exe on Windows).
# CCR_SHELL=/bin/zsh

# Set to "production" to enforce HTTPS-only session cookies.
# Only do this when you're terminating TLS in front of this server.
# NODE_ENV=production

# macOS only. Each spawned `claude` is wrapped in sandbox-exec so it can only
# write inside its session folder (+ ~/.claude + temp) and cannot READ sibling
# projects or climb above the session folder. The Node server itself keeps full
# filesystem access. Enabled by default on macOS. Set to 0 to disable.
# CLAUDE_SANDBOX=0
