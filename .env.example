# ── Required ──────────────────────────────────────────────────────────────────

# Create a GitHub OAuth App at https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Must match the "Authorization callback URL" on your OAuth app exactly.
# Use https:// in production.
GITHUB_CALLBACK_URL=http://localhost:4000/auth/github/callback

# Long random string. Generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_a_long_random_string

# Only this GitHub username is allowed to sign in.
# If unset, any GitHub user can log in (NOT recommended).
ALLOWED_GITHUB_USER=your_github_username

# ── Optional ──────────────────────────────────────────────────────────────────

# HTTP port. Default: 4000.
PORT=4000

# Root directory that the project picker scans.
# Sessions are restricted to subdirectories of this path.
# Leave unset to disable the project picker.
# BASE_DIR=/home/you/projects

# Absolute path to the `claude` binary.
# Set this when running under PM2 / systemd where PATH may not include ~/.local/bin.
# CLAUDE_PATH=/home/you/.local/bin/claude

# Set to "production" to enforce HTTPS-only session cookies.
# NODE_ENV=production
