{
  "name": "claude-code-remote",
  "version": "2.0.3",
  "description": "Self-hosted control plane for Claude Code — operate your own main PC's AI from any phone or browser. Runs on your Claude subscription via `claude -p`, reserves prompts to fire the moment a rate limit clears, and keeps one shared context and progress across every device.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "ai",
    "coding-agent",
    "web-ui",
    "remote",
    "self-hosted",
    "pwa"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "adm-zip": "^0.5.17",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "multer": "^2.1.1",
    "node-pty": "^1.0.0",
    "qrcode": "^1.5.4",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "node-pty"
    ]
  }
}
